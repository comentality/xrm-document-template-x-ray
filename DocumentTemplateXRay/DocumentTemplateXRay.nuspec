<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2012/06/nuspec.xsd">
  <metadata>
    <id>DocumentTemplateXRay</id>
    <version>1.2.14</version>
    <title>Document Template X-Ray</title>
    <authors>Comentality</authors>
    <license type="expression">MIT</license>
    <projectUrl>https://github.com/kk/xrm-document-x-ray</projectUrl>
    <icon>icon.png</icon>
    <description>Extract Dynamics 365 field references from Word document templates. Analyzes DOCX templates to reveal all entity fields, conditions, and relationships used.</description>
    <releaseNotes>v1.2.14 - Initial Plugin Store release.</releaseNotes>
    <tags>XrmToolBox Dynamics365 CRM DocumentTemplate PowerPlatform</tags>
    <dependencies>
      <group targetFramework=".NETFramework4.8">
        <dependency id="XrmToolBox" version="1.2025.7.71" />
      </group>
    </dependencies>
  </metadata>
  <files>
    <file src="bin\Release\net48\DocumentTemplateXRay.dll" target="Plugins\DocumentTemplateXRay.dll" />
    <file src="icon.png" target="icon.png" />
  </files>
</package>
